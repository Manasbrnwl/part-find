generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  date_of_birth DateTime?
  phone_number  String?   @unique
  fcm_token     String?
  jwt_token     String?
  otp           String?
  otp_exp       DateTime?
  weight        Float?
  gender        String?
  address       String?
  state         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  height        Float?
  is_active     Boolean   @default(true)
  english_level String?
  role          Role?     @default(USER)

  // Recruiter-specific fields
  recruiter_company_name         String?
  recruiter_type                 String? // Individual, Company, Agency, Event Organizer
  recruiter_company_registration String? // GST/PAN (optional)
  recruiter_company_address      String?
  recruiter_company_logo         String? // URL to logo image

  // Relations
  posts               Post[]
  userImages          images[]
  comments            postApplied[]
  savePosts           savePosts[]
  UserCategory        UserCategory[]
  recruiterIndustries RecruiterIndustry[] @relation("UserToIndustries")
  recruiterGigTypes   RecruiterGigType[]  @relation("UserToGigTypes")
  ratingsReceived     Rating[]            @relation("UserRatings")
  ratingsGiven        Rating[]            @relation("RecruiterRatings")
  refreshTokens       RefreshToken[]
  experience          String[]            @default([])
  education           Json                @default("[]")
  flaggedReports      FlaggedUser[]
  certificates        Certificate[]       @relation("UserCertificates")
  issuedCertificates  Certificate[]       @relation("RecruiterCertificates")
}

model RecruiterIndustry {
  id         Int      @id @default(autoincrement())
  user_id    String
  industry   String // Events, Hospitality, Retail, Logistics, etc.
  created_at DateTime @default(now()) @db.Timestamp(6)
  is_active  Boolean  @default(true)
  user       User     @relation("UserToIndustries", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, industry])
}

model RecruiterGigType {
  id         Int      @id @default(autoincrement())
  user_id    String
  gigType    String // Promoters, Ushers, Event Staff, Security, etc.
  created_at DateTime @default(now()) @db.Timestamp(6)
  is_active  Boolean  @default(true)
  user       User     @relation("UserToGigTypes", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, gigType])
}

model UserCategory {
  id          Int         @id @default(autoincrement())
  user_id     String
  category_id Int
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @db.Timestamp(6)
  is_active   Boolean     @default(true)
  JobCategory JobCategory @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_category")
  User        User        @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_post")

  @@unique([user_id, category_id], map: "user_category_unique")
}

model images {
  id        String   @id @default(uuid())
  userId    String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Post {
  id             String         @id @default(uuid())
  userId         String
  title          String         @db.VarChar(255)
  content        String?
  requirement    String?
  total          Int            @default(1)
  boys           Int?           @default(0)
  girls          Int?           @default(0)
  endDate        DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  location       String?
  payment        Float?
  paymentDate    DateTime?
  responsibility String?
  role           String?
  lunch          Boolean        @default(false)
  startDate      DateTime       @default(now())
  is_active      Boolean        @default(true)
  company_name   String?
  latitude       Float?
  longitude      Float?
  category       String?
  user           User           @relation(fields: [userId], references: [id])
  PostCategory   PostCategory[]
  comments       postApplied[]
  savePosts      savePosts[]
  ratings        Rating[]
  certificates   Certificate[]

  @@unique([userId, title, startDate], map: "post_unique")
}

model postApplied {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    Status?  @default(PENDING)
  remark    String?
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId], map: "user_post_unique")
}

model JobCategory {
  id           Int            @id @default(autoincrement())
  name         String         @unique @db.VarChar(100)
  description  String?
  is_active    Boolean        @default(true)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime?      @db.Timestamp(6)
  PostCategory PostCategory[]
  UserCategory UserCategory[]
}

model PostCategory {
  id          Int         @id @default(autoincrement())
  post_id     String
  category_id Int
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @db.Timestamp(6)
  is_active   Boolean     @default(true)
  JobCategory JobCategory @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_category")
  Post        Post        @relation(fields: [post_id], references: [id], onUpdate: NoAction, map: "fk_post")

  @@unique([post_id, category_id], map: "post_category_unique")
}

model savePosts {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId], map: "user_save_post_unique")
  @@index([userId], map: "user_save_post_index")
  @@index([postId], map: "post_save_post_index")
}

enum Role {
  USER
  ADMIN
  RECRUITER
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  NOT_PRESENT
}

model Rating {
  id          String   @id @default(uuid())
  postId      String
  recruiterId String // The recruiter giving the rating
  userId      String // The user being rated
  rating      Int // 1-5 stars
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  recruiter User @relation("RecruiterRatings", fields: [recruiterId], references: [id], onDelete: Cascade)
  user      User @relation("UserRatings", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "rating_post_user_unique") // One rating per user per job
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  deviceInfo String?
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model FlaggedUser {
  id        String   @id @default(uuid())
  userId    String
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id          String   @id @default(uuid())
  userId      String
  postId      String
  recruiterId String
  rating      Int
  issuedAt    DateTime @default(now())

  user      User @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  recruiter User @relation("RecruiterCertificates", fields: [recruiterId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "certificate_post_user_unique")
}

model AppVersion {
  id           String   @id @default(uuid())
  version      String
  buildNumber  Int      @default(1)
  platform     String   @default("android")
  forceUpdate  Boolean  @default(false)
  message      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
