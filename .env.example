#Port configuration
PORT = 4000

# JWT configuration
JWT_SECRET=<your-jwt-secret-key>

# Email configuration
EMAIL_USER=<your-email>
EMAIL_PASS=<your-email-password>
# Optional custom SMTP configuration (default is Gmail if host is omitted)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Database configuration
DATABASE_URL=<your-database-url>

# Firebase Configuration
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<your-firebase-client-email>
FIREBASE_PRIVATE_KEY=<your-firebase-private-key>
FIREBASE_VAPID_KEY=<your-firebase-vapid-key-for-web-push>

# Redis configuration (Upstash or local)
REDIS_URL=rediss://default:<your-upstash-password>@<your-upstash-host>.upstash.io:6379

# Node environment
NODE_ENV=development